{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "tsbuild",
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "noEmit": false,
    "useDefineForClassFields": true
  },
  "include": ["src"],
  "references": [{ "path": "../shared" }]
}
